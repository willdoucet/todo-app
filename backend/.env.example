# Copy this file to backend/.env (the filename must be exactly .env) and
# fill in any values your local stack needs beyond the Postgres defaults.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=todo_app

DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# M5 PR1 — auth secrets are REQUIRED for protected routes (anything that's
# not /, /healthz, /auth/*, /uploads/*). Without them,
# every protected request returns 500 and the app is unusable. Generate a
# JWT secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# JWT_SECRET_KEY must be ≥32 chars and must NOT contain any of:
# changeme, change-me, your-secret, your_secret, placeholder, example,
# replace-me, replace_me, todo, default, insecure, test-key, test_key.
# HOUSEHOLD_ACCESS_KEY can be any non-empty string — it gates /auth/register
# so only people with the shared key can create the singleton account.
JWT_SECRET_KEY=
HOUSEHOLD_ACCESS_KEY=

# APP_ENV controls fail-closed behavior. Leave unset for local dev (auth
# config errors degrade to a warning); set to "production" only in real
# production where missing/invalid auth secrets MUST crash startup.
APP_ENV=development
